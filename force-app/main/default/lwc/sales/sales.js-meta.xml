<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata" fqn="sales">
    <apiVersion>65.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Sales</masterLabel>
    <description>Add a classic greeting to any page.</description>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <property name="name" type="String" label="Name" placeholder="Sales!"
                description="Enter the name of the person to greet." />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>