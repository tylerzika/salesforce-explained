public with sharing class ModelsApiService {
  // Centralize the model choice here so future org-specific model changes do
  // not force edits across scripts, controllers, and background jobs.
  // TAOCP lens: keep important control parameters in one addressable place.
  private static final String DEFAULT_MODEL_NAME = 'sfdc_ai__DefaultBedrockAnthropicClaude45Haiku';

  // Tests replace this seam with a fake so they verify our wrapper contract
  // without depending on live model behavior or external service availability.
  // SICP lens: treat the runtime model call as an interchangeable procedure
  // behind an abstraction barrier, not as a hardwired global fact.
  @TestVisible
  private static ModelsInvoker invoker = new RuntimeModelsInvoker();

  public class ModelsApiServiceException extends Exception {
  }

  public class MessageInput {
    public String role;
    public String content;

    public MessageInput(String role, String content) {
      // Symbolic transformation note: a chat message is not "just a string."
      // It is a typed unit of intent inside a small language of roles +
      // content, which is exactly why we wrap it instead of passing raw text
      // around the codebase without structure.
      this.role = role;
      this.content = content;
    }
  }

  public class GenerationResult {
    public Boolean success;
    public String text;
    public String generationId;
    public String modelName;
    public String errorCode;
    public String errorMessage;
  }

  // This small internal DTO keeps the rest of the service insulated from the
  // verbose autogenerated Models API response graph.
  // What used to look like "just string manipulation" is really symbolic
  // transformation work: shape uncertain language IO into a compact, stable
  // internal representation the rest of the program can reason about.
  public class InvocationResult {
    public Boolean success;
    public String text;
    public String generationId;
    public String errorCode;
    public String errorMessage;
  }

  // Chat is the primary abstraction because future lead research, summarizers,
  // and assistant-style workflows all fit message-based interactions better
  // than raw prompt strings.
  // SICP easter egg: this is the beginning of a tiny domain language for Apex
  // inference work, where roles and messages are the primitive forms.
  public static GenerationResult generateFromMessages(List<MessageInput> messages) {
    validateMessages(messages);
    return toGenerationResult(invoker.invokeChatGeneration(messages));
  }

  // Keep the prompt helper because it is convenient for scripts and quick
  // experiments, even though chat is the more future-proof API shape.
  // Think of this as a REPL-like entry point: useful for local exploration,
  // but not the strongest abstraction for larger systems.
  public static GenerationResult generateFromPrompt(String promptText) {
    if (String.isBlank(promptText)) {
      throw new ModelsApiServiceException('Prompt text is required.');
    }

    return toGenerationResult(invoker.invokeGeneration(promptText));
  }

  private static GenerationResult toGenerationResult(InvocationResult invocationResult) {
    GenerationResult result = new GenerationResult();
    // Symbolic transformation again: this method is a boundary where noisy
    // provider-specific response structure is compressed into one portable
    // semantic object the rest of the Apex code can reason about.
    result.success = invocationResult.success;
    result.text = invocationResult.text;
    result.generationId = invocationResult.generationId;
    result.modelName = DEFAULT_MODEL_NAME;
    result.errorCode = invocationResult.errorCode;
    result.errorMessage = invocationResult.errorMessage;
    return result;
  }

  private static void validateMessages(List<MessageInput> messages) {
    if (messages == null || messages.isEmpty()) {
      throw new ModelsApiServiceException('At least one chat message is required.');
    }

    for (Integer messageIndex = 0; messageIndex < messages.size(); messageIndex++) {
      MessageInput message = messages[messageIndex];
      if (message == null) {
        throw new ModelsApiServiceException('Message at index ' + messageIndex + ' is required.');
      }
      if (String.isBlank(message.role)) {
        throw new ModelsApiServiceException('Message role is required at index ' + messageIndex + '.');
      }
      if (!isAllowedRole(message.role)) {
        throw new ModelsApiServiceException(
          'Message role must be system, user, or assistant at index ' + messageIndex + '.'
        );
      }
      if (String.isBlank(message.content)) {
        throw new ModelsApiServiceException('Message content is required at index ' + messageIndex + '.');
      }
    }
  }

  private static Boolean isAllowedRole(String role) {
    String normalizedRole = role == null ? null : role.trim().toLowerCase();
    return normalizedRole == 'system' || normalizedRole == 'user' || normalizedRole == 'assistant';
  }

  private static InvocationResult fromGenerationException(aiplatform.ModelsAPI.createGenerations_ResponseException e) {
    return failureResult(e.responseCode, firstError(
      e.Code400,
      e.Code401,
      e.Code403,
      e.Code423,
      e.Code429,
      e.Code500,
      e.Code503,
      e.defaultResponse
    ));
  }

  private static InvocationResult fromChatException(aiplatform.ModelsAPI.createChatGenerations_ResponseException e) {
    return failureResult(e.responseCode, firstError(
      e.Code400,
      e.Code401,
      e.Code403,
      e.Code423,
      e.Code429,
      e.Code500,
      e.Code503,
      e.defaultResponse
    ));
  }

  // Provider failures are returned, not thrown, because callers often want to
  // render a reviewable error state. Input validation remains an exception
  // because blank prompts and malformed messages are programmer mistakes.
  // First-principles boundary: deterministic caller errors are one category;
  // stochastic remote-system outcomes are another and should be modeled as such.
  private static InvocationResult failureResult(Integer responseCode, aiplatform.ModelsAPI_Error error) {
    InvocationResult result = new InvocationResult();
    result.success = false;
    result.errorCode = error != null && !String.isBlank(error.errorCode)
      ? error.errorCode
      : 'HTTP_' + String.valueOf(responseCode);
    result.errorMessage = error != null && !String.isBlank(error.message)
      ? error.message
      : 'Models API request failed with response code ' + String.valueOf(responseCode) + '.';
    return result;
  }

  private static aiplatform.ModelsAPI_Error firstError(
    aiplatform.ModelsAPI_Error code400,
    aiplatform.ModelsAPI_Error code401,
    aiplatform.ModelsAPI_Error code403,
    aiplatform.ModelsAPI_Error code423,
    aiplatform.ModelsAPI_Error code429,
    aiplatform.ModelsAPI_Error code500,
    aiplatform.ModelsAPI_Error code503,
    aiplatform.ModelsAPI_Error defaultResponse
  ) {
    for (aiplatform.ModelsAPI_Error errorValue : new List<aiplatform.ModelsAPI_Error>{
      code400,
      code401,
      code403,
      code423,
      code429,
      code500,
      code503,
      defaultResponse
    }) {
      if (errorValue != null) {
        return errorValue;
      }
    }
    return null;
  }

  public virtual class ModelsInvoker {
    public virtual InvocationResult invokeGeneration(String promptText) {
      throw new ModelsApiServiceException('Models invoker not implemented.');
    }

    public virtual InvocationResult invokeChatGeneration(List<MessageInput> messages) {
      throw new ModelsApiServiceException('Models invoker not implemented.');
    }
  }

  private class RuntimeModelsInvoker extends ModelsInvoker {
    public override InvocationResult invokeGeneration(String promptText) {
      aiplatform.ModelsAPI.createGenerations_Request request = new aiplatform.ModelsAPI.createGenerations_Request();
      request.modelName = DEFAULT_MODEL_NAME;

      aiplatform.ModelsAPI_GenerationRequest requestBody = new aiplatform.ModelsAPI_GenerationRequest();
      requestBody.prompt = promptText;
      request.body = requestBody;

      try {
        aiplatform.ModelsAPI modelsApi = new aiplatform.ModelsAPI();
        aiplatform.ModelsAPI.createGenerations_Response response = modelsApi.createGenerations(request);

        InvocationResult result = new InvocationResult();
        result.success = true;
        result.text = response.Code200.generation.generatedText;
        result.generationId = response.Code200.generation.id;
        return result;
      } catch (aiplatform.ModelsAPI.createGenerations_ResponseException e) {
        return ModelsApiService.fromGenerationException(e);
      }
    }

    public override InvocationResult invokeChatGeneration(List<MessageInput> messages) {
      aiplatform.ModelsAPI.createChatGenerations_Request request = new aiplatform.ModelsAPI.createChatGenerations_Request();
      request.modelName = DEFAULT_MODEL_NAME;

      aiplatform.ModelsAPI_ChatGenerationsRequest requestBody = new aiplatform.ModelsAPI_ChatGenerationsRequest();
      requestBody.messages = new List<aiplatform.ModelsAPI_ChatMessageRequest>();

      for (MessageInput message : messages) {
        aiplatform.ModelsAPI_ChatMessageRequest messageRequest = new aiplatform.ModelsAPI_ChatMessageRequest();
        messageRequest.role = message.role.trim().toLowerCase();
        messageRequest.content = message.content;
        requestBody.messages.add(messageRequest);
      }

      request.body = requestBody;

      try {
        aiplatform.ModelsAPI modelsApi = new aiplatform.ModelsAPI();
        aiplatform.ModelsAPI.createChatGenerations_Response response = modelsApi.createChatGenerations(request);

        InvocationResult result = new InvocationResult();
        result.success = true;

        // Minimal wrapper rule: use the first generation only. A fuller service
        // could expose multiple candidates, tool traces, or richer metadata.
        // TAOCP reminder: start with one simple output convention you can study
        // and measure before broadening the state space.
        if (
          response.Code200 != null &&
          response.Code200.generationDetails != null &&
          response.Code200.generationDetails.generations != null &&
          !response.Code200.generationDetails.generations.isEmpty()
        ) {
          aiplatform.ModelsAPI_ChatMessage generatedMessage = response.Code200.generationDetails.generations[0];
          result.text = generatedMessage.content;
          result.generationId = generatedMessage.id;
        }

        return result;
      } catch (aiplatform.ModelsAPI.createChatGenerations_ResponseException e) {
        return ModelsApiService.fromChatException(e);
      }
    }
  }
}
