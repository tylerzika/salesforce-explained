<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Email_Required_For_Qualified_Leads</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status, "Qualified"),
    ISBLANK(Email)
)</errorConditionFormula>
    <errorDisplayField>Email</errorDisplayField>
    <errorMessage>Email is required for qualified leads to enable proper conversion.</errorMessage>
</ValidationRule>
