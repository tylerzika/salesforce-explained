<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Email_Required_For_Converted_Leads</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    IsConverted,
    ISBLANK(Email)
)</errorConditionFormula>
    <errorDisplayField>Email</errorDisplayField>
    <errorMessage>Email is required before converting a lead.</errorMessage>
</ValidationRule>
