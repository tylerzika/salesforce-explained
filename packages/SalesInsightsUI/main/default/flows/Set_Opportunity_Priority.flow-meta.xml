<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>Sets CalculatedPriority__c before save without Apex action</description>
    <label>Set Opportunity Priority</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <assignments>
        <name>Calculate_Priority_Locally</name>
        <label>Calculate Priority Locally</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <assignmentItems>
            <assignToReference>$Record.CalculatedPriority__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>{!IF(AND(NOT(ISBLANK($Record.Amount)), $Record.Amount >= 100000), "High", IF(AND(NOT(ISBLANK($Record.Amount)), $Record.Amount >= 25000), "Medium", "Low"))}</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <recordUpdates>
        <name>Update_Opportunity_Priority</name>
        <label>Update Opportunity Priority</label>
        <locationX>176</locationX>
        <locationY>242</locationY>
        <inputAssignments>
            <field>CalculatedPriority__c</field>
            <value>
                <elementReference>$Record.CalculatedPriority__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Calculate_Priority_Locally</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Amount</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
