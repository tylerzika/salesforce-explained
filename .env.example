# Example Environment Variables for Salesforce Authentication
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# Your Salesforce username (email address)
SF_USERNAME=your.email@example.com

# The Consumer Key from your Connected App
SF_CLIENT_ID=your_consumer_key_here

# The contents of your server.key file
# You can use: export SF_JWT_KEY="$(cat server.key)"
# Or paste the entire key including BEGIN and END lines
SF_JWT_KEY=-----BEGIN RSA PRIVATE KEY-----
...your private key here...
-----END RSA PRIVATE KEY-----
